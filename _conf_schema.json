{
  "output_format": {
    "type": "string",
    "description": "动图输出格式：GIF / APNG / WEBP",
    "enum": [
      "GIF",
      "APNG",
      "WEBP"
    ],
    "default": "GIF"
  },
  "default_scale": {
    "type": "float",
    "description": "视频转GIF默认缩放(0.1-1.0)",
    "default": 0.3
  },
  "default_fps": {
    "type": "int",
    "description": "视频转GIF默认采样参数(内部fps)",
    "default": 10
  },
  "max_gif_duration": {
    "type": "float",
    "description": "截取视频最大时长(秒)",
    "default": 10.0
  },
  "max_video_size_mb": {
    "type": "float",
    "description": "允许处理的视频最大体积(MB)",
    "default": 50.0
  },
  "max_download_size_mb": {
    "type": "float",
    "description": "下载最大体积(MB)",
    "default": 50.0
  },
  "max_image_size_mb": {
    "type": "float",
    "description": "普通图片最大体积(MB)",
    "default": 15.0
  },
  "max_gif_size_mb": {
    "type": "float",
    "description": "GIF最大体积(MB)",
    "default": 20.0
  },
  "precheck_file_size_mb": {
    "type": "float",
    "description": "打开/解码前文件预检上限(MB)",
    "default": 100.0
  },
  "max_gif_frames": {
    "type": "int",
    "description": "单个GIF允许处理的最大帧数",
    "default": 200
  },
  "max_gif_total_pixels": {
    "type": "int",
    "description": "GIF总像素上限(帧数x单帧像素)",
    "default": 16000000
  },
  "max_image_pixels": {
    "type": "int",
    "description": "单张静图最大像素数",
    "default": 25000000
  },
  "enable_auto_compress": {
    "type": "bool",
    "description": "处理时自动压缩过大图片",
    "default": true
  },
  "max_compress_dimension": {
    "type": "int",
    "description": "自动压缩时最长边像素上限",
    "default": 2048
  },
  "gif_max_colors": {
    "type": "int",
    "description": "GIF最大颜色数(2-256)",
    "default": 256
  },
  "crop_output_format": {
    "type": "string",
    "description": "自动裁切输出格式",
    "options": [
      "PNG",
      "JPEG"
    ],
    "default": "PNG"
  },
  "max_concurrent_tasks": {
    "type": "int",
    "description": "最大并发任务数",
    "default": 2
  },
  "task_timeout_sec": {
    "type": "float",
    "description": "单任务超时(秒)",
    "default": 120.0
  },
  "max_queue_waiting": {
    "type": "int",
    "description": "排队上限",
    "default": 8
  }
}
